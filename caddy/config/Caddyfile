{
        debug
        auto_https off
        order coraza_waf after rate_limit
        log {
                output file /logs/caddy.log {
                        roll_size 100mb
                        roll_keep 5
                        roll_keep_for 720h
                        mode 0644
                }
                format json
                level debug
                exclude http.handlers.waf
        }

        log rate_limit_log {
                output file /logs/rate_limit.log {
                        roll_size 100mb
                        roll_keep 5
                        roll_keep_for 720h
                        mode 0644
                }
                format json
                level info

                include http.handlers.rate_limit
        }
}


(access_log) {
        log {
                output file /logs/access.log {
                        roll_size 100mb
                        roll_keep 5
                        roll_keep_for 720h
                        mode 0644
                }
                format json
                level debug
        }
}
# 定义限流策略片段
(rate_limit_policy) {
        rate_limit {
                # 定义一个名为 "global_zone" 的区域
                zone global_zone {
                        match {
                                # 匹配所有请求，或者你可以指定特定的 path
                                path_regexp .*
                        }
                        key {remote_host} # 关键：按客户端 IP (remote_host) 进行计数
                        events 100 # 阈值：允许 100 次请求
                        window 10s # 时间窗口：在 10 秒内
                }

                # 如果超过阈值，返回 429 Too Many Requests
                handle {
                        respond "Too Many Requests - IP Rate Limited" 429
                }
        }
}

(waf) {
        coraza_waf {
                load_owasp_crs
                directives `
                Include @coraza.conf-recommended
                Include @crs-setup.conf.example
                Include @owasp_crs/*.conf
                
                SecDefaultAction "phase:3,log,auditlog,pass"
                SecDefaultAction "phase:4,log,auditlog,pass"
                SecDefaultAction "phase:5,log,auditlog,pass"
                SecRuleEngine On

                # --- 自定义规则 ---
                # 1. 强化扫描器拦截 (增加一些现代常见扫描器关键字)
                SecRule REQUEST_HEADERS:User-Agent "@rx (?i)(sqlmap|nmap|masscan|nessus|openvas|hydra|medusa|burp|python-requests|scrapy|dirbuster|gobuster)" \
                "id:1001,phase:1,deny,status:403,msg:'Blocked known scanner/bot User-Agent'"

                # 2. 敏感路径 (加上边界匹配)
                SecRule REQUEST_URI "@rx (?i)(\.git|\.env|\.svn|\.htaccess|phpinfo|phpmyadmin|wp-config)" \
                "id:1002,phase:1,deny,status:403,msg:'Sensitive path access blocked'"

                # 3. 响应状态码掩盖/拦截(如果后端服务器尝试返回 406 Not Acceptable 状态码，WAF 会将其拦截，强制改为返回 403 Forbidden)
                SecRule RESPONSE_STATUS "@rx 406" "id:103,phase:3,t:none,deny,status:403"

                # --- 日志配置 ---
                SecAuditEngine RelevantOnly
                SecAuditLog /logs/waf_audit.log
                SecAuditLogFormat json

                #SecDebugLog /logs/waf_debug.log
                #SecDebugLogLevel 9
                `
        }

        handle_errors 403 {
                header X-Blocked "true"
                respond "403 Forbidden" 403
        }
}

:8080, :8443, :80, :8888 {
        import rate_limit_policy
        import waf
        import access_log
        respond "您的IP地址是: {remote_host}
"
}
